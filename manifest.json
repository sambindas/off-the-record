{
  "manifest_version": 3,
  "name": "Off the Record",
  "version": "1.0.0",
  "description": "Browse your chosen sites off the record. History for those domains is auto-erased the moment it's written, every page, every link.",
  "permissions": ["history", "storage", "tabs", "webNavigation", "alarms"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "off-the-record@samuelbindas.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Off the Record"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  }
}
